# Database - Update with your MySQL credentials
# For XAMPP with no password: mysql+pymysql://root:@localhost:3306/fah_retail
# For MySQL with password: mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/fah_retail
DATABASE_URL=mysql+pymysql://root:@localhost:3306/fah_retail

# JWT
SECRET_KEY=fah-retail-secret-key-dev-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloudinary (optional for now)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (optional for now)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# App
APP_NAME=FAH Retail
DEBUG=true
